# Copy to .env on the EC2 instance before starting:
#   cp env.ec2.example .env

# Set automatically by scripts/ec2-setup.sh (or set your Elastic IP / domain)
REACT_APP_API_URL=http://YOUR_EC2_PUBLIC_IP
KF_CORS_ORIGINS=http://YOUR_EC2_PUBLIC_IP

# Change before production
SECRET_KEY=change-me-to-a-long-random-string
POSTGRES_PASSWORD=change-me-strong-db-password

ACCESS_TOKEN_EXPIRE_MINUTES=480

# Bedrock (uses EC2 instance IAM role — no API key needed)
BEDROCK_ENABLED=true
DEFAULT_LLM_PROVIDER=bedrock
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-5-20250929-v1:0
ENABLED_LLM_PROVIDERS=openai,bedrock

# Optional: OpenAI instead of Bedrock
# BEDROCK_ENABLED=false
# DEFAULT_LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
